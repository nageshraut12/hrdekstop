{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "git-init",
			"type": "shell",
			"command": "git",
			"args": ["init"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "git-add",
			"type": "shell",
			"command": "git",
			"args": ["add", "."],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "git-commit",
			"type": "shell",
			"command": "git",
			"args": ["commit", "-m", "Initial commit: HR Dashboard full-stack application"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "git-remote-add",
			"type": "shell",
			"command": "git",
			"args": ["remote", "add", "origin", "https://github.com/nageshraut12/hrdekstop.git"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "git-push-master",
			"type": "shell",
			"command": "git",
			"args": ["push", "-u", "origin", "master"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		}
	]
}